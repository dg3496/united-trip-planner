# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# From Supabase: Settings > API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# UUID of the demo user row in the users table (from 002_seed.sql)
VITE_DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# ─── Supabase Edge Function secrets (set via CLI, never in .env) ─────────────
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY is server-side ONLY. Never put it here.
